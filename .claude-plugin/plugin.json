{
    "name": "grover",
    "description": "A plugin for Grover",
    "version": "2.0.0",
    "author": {
        "name": "Will Fitch"
    },
    "mcpServers": {
        "grover": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-remote",
                "https://grover-chat-git-admin-mcp-server-go-code.vercel.app/mcp",
                "--header",
                "Authorization:${GROVER_AUTH_HEADER}"
            ],
            "env": {
                "GROVER_AUTH_HEADER": "Bearer ${GROVER_ACCESS_TOKEN}"
            }
        }
    }
}
